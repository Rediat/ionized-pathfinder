{
  "manifest_version": 3,
  "name": "Edge EPUB Reader",
  "version": "1.0.0",
  "description": "A beautiful EPUB reader inspired by the classic Microsoft Edge reading experience. Open .epub files directly in your browser.",
  "permissions": [
    "storage",
    "webNavigation",
    "contextMenus"
  ],
  "icons": {
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": "icons/icon128.png",
    "default_title": "Open EPUB Reader"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "reader.html",
        "reader.css",
        "reader.js",
        "lib/*",
        "icons/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}